{
  "name": "LandrayGitTool",
  "version": "1.5.2",
  "description": "Git合并辅助工具 - Electron+React版本",
  "main": "public/electron.js",
  "homepage": ".",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-pack": "npm run build && electron-builder build -c.extraMetadata.main=build/electron.js",
    "electron-build-win": "npm run build && electron-builder --win",
    "electron-build-win-portable": "npm run build && electron-builder --win portable",
    "electron-build-mac": "npm run build && electron-builder --mac",
    "electron-build-mac-dmg": "npm run build && electron-builder --mac dmg",
    "preelectron-pack": "npm run build",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "antd": "^5.12.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.2",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "react-window": "^2.2.7",
    "simple-git": "^3.21.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.landray.LandrayGitTool",
    "productName": "LandrayGitTool",
    "copyright": "Copyright © 2024 蓝凌软件",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "build/electron.js"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "蓝凌软件"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LandrayGitTool"
    },
    "portable": {
      "artifactName": "LandrayGitTool-便携版-${version}.exe"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  }
}
